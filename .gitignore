ui/src/lib/*.js
ui/src/lib/*.d.ts
ui/src/lib/*.js.map
ui/src/lib/*.d.ts.map

# Test mock build artifacts
tests/mocks/*.js
tests/mocks/*.d.ts
tests/mocks/*.js.map
tests/mocks/*.d.ts.map
tests/mocks/fixtures/*.js
tests/mocks/fixtures/*.d.ts
tests/mocks/fixtures/*.js.map
tests/mocks/fixtures/*.d.ts.map

# Bar demo scaffolding (local dev only)
_serve*.ts
_serve*.log
